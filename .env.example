# Copy to .env.local and fill in. Never commit real keys.

# Required — the daily generator calls the Anthropic API to write the posts.
ANTHROPIC_API_KEY=

# Optional — enables mirroring generated posts into the new site's Supabase
# `blog_posts` table (upsert per slug), ALONGSIDE the .mdx writes.
# Leave BOTH unset for a dry run: the .mdx files are still written, but no DB
# rows are touched ("DB publish skipped (no Supabase env)"). Set BOTH to write.
# Use the SERVICE ROLE key (server-side only) — it bypasses RLS. Never expose it
# client-side or commit it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
